<script>
// ── SYMBOL CONFIG ──────────────────────────────────────────────
const SYMBOLS = {
  NQ:  { label:'NQ / MNQ', name:'Nasdaq 100 Futures',  base:21840, atr:310,  tickSize:0.25 },
  ES:  { label:'ES / MES', name:'S&P 500 E-Mini',       base:5920,  atr:68,   tickSize:0.25 },
  MCL: { label:'MCL',      name:'Micro Crude Oil',       base:75.40, atr:1.85, tickSize:0.01, decimals:2 },
  GC:  { label:'GC',       name:'Gold Futures',          base:4157,  atr:55,   tickSize:0.1  },
  SI:  { label:'SI',       name:'Silver Futures',         base:32.80, atr:0.95, tickSize:0.005, decimals:3 },
};

const LOCKED = ['ES','MCL','GC','SI'];
let currentSymbol = 'NQ';
let chartInstance = null;
let priceNow = SYMBOLS.NQ.base;

// ── TAPE DATA ──────────────────────────────────────────────────
const tapeSymbols = [
  {sym:'NQ', base:21840}, {sym:'ES', base:5920},
  {sym:'MCL', base:75.40, dec:2}, {sym:'GC', base:4157},
  {sym:'SI', base:32.80, dec:3}, {sym:'RTY', base:2210},
  {sym:'YM', base:43800},
];

function buildTape() {
  const tape = document.getElementById('tapeScroll');
  tape.innerHTML = tapeSymbols.map(s => {
    const chg = (Math.random() - 0.47) * (s.base * 0.008);
    const px = s.base + chg;
    const pct = (chg / s.base * 100).toFixed(2);
    const up = chg >= 0;
    const dec = s.dec || 2;
    return `<span class="tape-item">
      <span class="tape-sym">${s.sym}</span>
      <span class="tape-px">${px.toFixed(dec)}</span>
      <span class="${up ? 'tape-up' : 'tape-dn'}">${up ? '▲' : '▼'}${Math.abs(pct)}%</span>
    </span>`;
  }).join('<span class="tape-item" style="color:var(--border-hi)">|</span>');
}

// ── FORECAST ENGINE ────────────────────────────────────────────
function buildForecast(base, atr) {
  const labels = ['NOW','1H','2H','4H','EOD','D+1','D+2','D+3','D+4'];
  const drift = 0.00035;
  const volFactor = atr / base;
  const base_c=[], bull=[], bear=[], hi1=[], lo1=[], hi2=[], lo2=[];
  for (let i = 0; i <= 8; i++) {
    const t = i;
    const mu = base * (1 + drift * t);
    const sigma = base * volFactor * Math.sqrt(t + 0.25);
    base_c.push(+mu.toFixed(2));
    bull.push(+(mu + sigma * 1.28).toFixed(2));
    bear.push(+(mu - sigma * 1.28).toFixed(2));
    hi1.push(+(mu + sigma * 0.67).toFixed(2));
    lo1.push(+(mu - sigma * 0.67).toFixed(2));
    hi2.push(+(mu + sigma * 1.96).toFixed(2));
    lo2.push(+(mu - sigma * 1.96).toFixed(2));
  }
  return { labels, base_c, bull, bear, hi1, lo1, hi2, lo2 };
}

// ── KEY LEVELS ─────────────────────────────────────────────────
function buildLevels(base, atr) {
  return [
    { tag:'R3', val: base + atr*1.4,  cls:'lv-res' },
    { tag:'R2', val: base + atr*0.85, cls:'lv-res' },
    { tag:'R1', val: base + atr*0.38, cls:'lv-res' },
    { tag:'POC',val: base + atr*0.06, cls:'lv-poc' },
    { tag:'PVT',val: base,             cls:'lv-pvt' },
    { tag:'S1', val: base - atr*0.34, cls:'lv-sup' },
    { tag:'S2', val: base - atr*0.78, cls:'lv-sup' },
    { tag:'S3', val: base - atr*1.35, cls:'lv-sup' },
  ];
}

// ── BIAS ENGINE ────────────────────────────────────────────────
function computeBias() {
  const scenarios = [
    { bull:64, bear:22, neu:14, score:'BULLISH',  col:'var(--bull)' },
    { bull:55, bear:30, neu:15, score:'BULLISH',  col:'var(--bull)' },
    { bull:28, bear:58, neu:14, score:'BEARISH',  col:'var(--bear)' },
    { bull:35, bear:40, neu:25, score:'NEUTRAL',  col:'var(--amber)' },
  ];
  return scenarios[Math.floor(Math.random() * scenarios.length)];
}

// ── CHART BUILDER ──────────────────────────────────────────────
function buildChart(fc) {
  const ctx = document.getElementById('forecastChart').getContext('2d');
  if (chartInstance) { chartInstance.destroy(); chartInstance = null; }

  const yMin = Math.min(...fc.lo2) - (Math.max(...fc.hi2) - Math.min(...fc.lo2)) * 0.08;
  const yMax = Math.max(...fc.hi2) + (Math.max(...fc.hi2) - Math.min(...fc.lo2)) * 0.08;
  // Simple level line drawer - runs after each chart render
  const _lvPlugin = {
    id:'lvLines',
    afterDraw(ch){
      if(!window._chartLevels) return;
      const c=ch.ctx, ya=ch.scales.y, xa=ch.scales.x;
      const L=xa.left, R=xa.right;
      // Only extend 30% of chart width from left
      const lineEnd = L + (R-L)*0.30;
      const px=window._chartLevels[0]?window._chartLevels[0].val:0;
      const atr=SYMBOLS[currentSymbol].atr;
      const dec=SYMBOLS[currentSymbol].decimals||2;
      c.save();
      window._chartLevels.forEach(function(lv){
        if(lv.val < ch.scales.y.min || lv.val > ch.scales.y.max) return;
        const y=ya.getPixelForValue(lv.val);
        const near=Math.abs(lv.val-window._chartPrice)<atr*0.35;
        const col=lv.cls==='lv-res'?'#ff3b5c':lv.cls==='lv-sup'?'#00ff94':lv.cls==='lv-poc'?'#00d4ff':'#ffb800';
        // Line
        c.beginPath();
        c.strokeStyle=col;
        c.globalAlpha=near?0.85:0.35;
        c.lineWidth=near?1.5:1;
        c.setLineDash(near?[]:[3,3]);
        c.moveTo(L,y);
        c.lineTo(lineEnd,y);
        c.stroke();
        // Label — just the tag name, right at end of line
        c.setLineDash([]);
        c.globalAlpha=near?1:0.5;
        c.font=(near?'bold ':'')+'11px JetBrains Mono,monospace';
        c.fillStyle=col;
        c.textAlign='left';
        const val=lv.val.toLocaleString('en-US',{minimumFractionDigits:dec,maximumFractionDigits:dec});
        c.fillText(lv.tag+' '+val, lineEnd+4, y+4);
        c.globalAlpha=1;
      });
      c.restore();
    }
  };

  chartInstance = new Chart(ctx, {
    plugins:[_lvPlugin],
    type: 'line',
    data: {
      labels: fc.labels,
      datasets: [
        {
          label: '95% lo',
          data: fc.lo2, fill: false,
          borderColor: 'transparent', pointRadius: 0, tension: 0.45
        },
        {
          label: 'Bull Zone',
          data: fc.bull,
          fill: '-1',
          backgroundColor: 'rgba(0,255,148,0.07)',
          borderColor: 'rgba(0,255,148,0.4)',
          borderWidth: 1.5,
          borderDash: [5,4],
          pointRadius: 0, tension: 0.45
        },
        {
          label: 'Inner hi',
          data: fc.hi1, fill: false,
          borderColor: 'transparent', pointRadius: 0, tension: 0.45
        },
        {
          label: '68% Band',
          data: fc.lo1,
          fill: '-1',
          backgroundColor: 'rgba(0,212,255,0.10)',
          borderColor: 'transparent',
          pointRadius: 0, tension: 0.45
        },
        {
          label: 'Base Case',
          data: fc.base_c,
          fill: false,
          borderColor: '#00d4ff',
          borderWidth: 2.5,
          pointRadius: [7, 3, 3, 3, 3, 3, 3, 3, 3],
          pointBackgroundColor: '#00d4ff',
          pointBorderColor: '#060810',
          pointBorderWidth: 1.5,
          tension: 0.45
        },
        {
          label: 'Bear Zone',
          data: fc.bear,
          fill: 1,
          backgroundColor: 'rgba(255,59,92,0.07)',
          borderColor: 'rgba(255,59,92,0.4)',
          borderWidth: 1.5,
          borderDash: [5,4],
          pointRadius: 0, tension: 0.45
        },
        {
          label: '95% hi',
          data: fc.hi2, fill: false,
          borderColor: 'transparent', pointRadius: 0, tension: 0.45
        },
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#0d1e38',
          borderColor: 'rgba(0,212,255,0.35)',
          borderWidth: 1,
          titleColor: '#00d4ff',
          bodyColor: '#c8d8f0',
          titleFont: { family: 'JetBrains Mono', size: 11 },
          bodyFont: { family: 'JetBrains Mono', size: 11 },
          callbacks: {
            label: ctx => {
              if (['95% lo','Inner hi','95% hi'].includes(ctx.dataset.label)) return null;
              const dec = SYMBOLS[currentSymbol].decimals || 2;
              return ' ' + ctx.dataset.label + ': ' + ctx.raw.toLocaleString('en-US',{minimumFractionDigits:dec,maximumFractionDigits:dec});
            }
          }
        }
      },
      scales: {
        x: {
          grid: { color: 'rgba(0,212,255,0.06)', lineWidth: 1 },
          ticks: { color: 'rgba(0,212,255,0.5)', font: { family:'JetBrains Mono', size:10 }, maxRotation: 0 }
        },
        y: {
          position: 'right',
          min: yMin, max: yMax,
          grid: { color: 'rgba(0,212,255,0.06)', lineWidth: 1 },
          ticks: {
            color: 'rgba(0,212,255,0.5)',
            font: { family:'JetBrains Mono', size:10 },
            callback: v => {
              const dec = SYMBOLS[currentSymbol].decimals || 2;
              return v.toLocaleString('en-US',{minimumFractionDigits:dec,maximumFractionDigits:dec});
            }
          }
        }
      }
    }
  });
}

// ── MAIN RENDER ────────────────────────────────────────────────
function render(sym) {
  const cfg = SYMBOLS[sym];
  const dec = cfg.decimals || 2;
  const price = cfg.base + (Math.random() - 0.47) * cfg.atr * 0.4;
  const chgPct = (Math.random() - 0.45) * 1.6;
  const isUp = chgPct >= 0;
  priceNow = price;

  // Header
  document.getElementById('tickerLbl').textContent = cfg.label;
  document.getElementById('priceDisplay').textContent = price.toLocaleString('en-US',{minimumFractionDigits:dec,maximumFractionDigits:dec});
  const chgEl = document.getElementById('chgBadge');
  chgEl.textContent = (isUp ? '+' : '') + chgPct.toFixed(2) + '%';
  chgEl.className = 'chg-badge ' + (isUp ? 'chg-up' : 'chg-down');

  // Timestamp
  const now = new Date();
  document.getElementById('timestamp').textContent =
    now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'}) + '  CT';

  // Forecast
  const fc = buildForecast(price, cfg.atr);
  const fcHi = Math.max(...fc.bull);
  const fcLo = Math.min(...fc.bear);
  const rng = fcHi - fcLo;

  document.getElementById('fcHi').textContent = fcHi.toLocaleString('en-US',{minimumFractionDigits:dec,maximumFractionDigits:dec});
  document.getElementById('fcLo').textContent = fcLo.toLocaleString('en-US',{minimumFractionDigits:dec,maximumFractionDigits:dec});
  document.getElementById('rng').textContent = rng.toFixed(dec) + ' pts';
  document.getElementById('atrVal').textContent = cfg.atr.toFixed(dec) + ' pts';

  const volOver = Math.random() > 0.45;
  const volPct = Math.round(Math.random() * 50 + 10);
  const volEl = document.getElementById('volSig');
  volEl.textContent = volOver ? 'HIGH +' + volPct + '%' : 'NORMAL';
  volEl.style.color = volOver ? 'var(--amber)' : 'var(--bull)';

  // Bias
  const bias = computeBias();
  document.getElementById('biasScore').textContent = bias.score;
  document.getElementById('biasScore').style.color = bias.col;
  document.getElementById('bullBar').style.width = bias.bull + '%';
  document.getElementById('bearBar').style.width = bias.bear + '%';
  document.getElementById('neuBar').style.width = bias.neu + '%';
  document.getElementById('bullPct').textContent = bias.bull + '%';
  document.getElementById('bearPct').textContent = bias.bear + '%';
  document.getElementById('neuPct').textContent = bias.neu + '%';

  // Levels
  const levels = buildLevels(price, cfg.atr);
  document.getElementById('levelsPanel').innerHTML = levels.map(l =>
    const rowCls = l.cls==='lv-res'?'row-res':l.cls==='lv-sup'?'row-sup':l.cls==='lv-poc'?'row-poc':'row-pvt';
    const tagCls = l.cls==='lv-res'?'lv-tag-res':l.cls==='lv-sup'?'lv-tag-sup':l.cls==='lv-poc'?'lv-tag-poc':'lv-tag-pvt';
    `<div class="level-row ${rowCls}">
      <span class="lv-tag ${tagCls}">${l.tag}</span>
      <span class="${l.cls}">${l.val.toLocaleString('en-US',{minimumFractionDigits:dec,maximumFractionDigits:dec})}</span>
    </div>`
  ).join('');

  // Confluence
  const bullConf = bias.score === 'BULLISH';
  const items = [
    { txt: 'Price ' + (isUp?'above':'below') + ' VWAP ' + (isUp?'+':'-') + Math.round(cfg.atr*0.08) + 'pts', bull: isUp },
    { txt: (bullConf?'20MA > 50MA (bull cross)':'50MA > 20MA (bear cross)'), bull: bullConf },
    { txt: 'RSI 14: ' + Math.round(50 + (Math.random()-0.4)*30) + (bullConf?' — trending':'  — watch OB'), bull: bullConf },
    { txt: 'Volume ' + (volOver?'> avg +'+volPct+'% (inst. activity)':'at avg (neutral)'), bull: volOver },
    { txt: 'Macro: Iran deal tailwind in play', bull: true },
    { txt: 'Fed Warsh hawkish — rate hike risk', bull: false },
  ];
  document.getElementById('confPanel').innerHTML = items.map(i =>
    `<div class="conf-line ${i.bull?'conf-bull':'conf-bear'}">${i.bull?'▲':'▼'} ${i.txt}</div>`
  ).join('');

  // TF Cards
  const tfCards = [
    { sig: bias.score,   cls: bias.score==='BULLISH'?'sig-bull':bias.score==='BEARISH'?'sig-bear':'sig-neu', detail: 'Open gap ' + (isUp?'up':' down') + ' expected' },
    { sig: isUp?'LONG BIAS':'SHORT BIAS', cls: isUp?'sig-bull':'sig-bear', detail: 'VWAP ' + (isUp?'reclaim':'rejection') + ' play' },
    { sig: bias.score==='BEARISH'?'NEUTRAL':'BULLISH', cls: bias.score==='BEARISH'?'sig-neu':'sig-bull', detail: 'Fed event risk present' },
    { sig: bullConf?'BULLISH':'BEARISH', cls: bullConf?'sig-bull':'sig-bear', detail: bullConf?'Price > all MAs':'Price < 20MA' },
    { sig: 'CAUTION', cls: 'sig-neu', detail: 'RSI approaching OB zone' },
    { sig: 'MIXED',   cls: 'sig-neu', detail: 'Iran deal vs Fed hike' },
  ];
  tfCards.forEach((t, i) => {
    const el = document.getElementById('tf' + i);
    el.textContent = t.sig;
    el.className = 'tf-signal ' + t.cls;
    document.getElementById('tf' + i + 'd').textContent = t.detail;
  });

  // Store levels for chart plugin
  window._chartLevels = levels;
  window._chartPrice  = price;

  // Store for level line plugin
  window._chartLevels = levels;
  window._chartPrice  = price;
  window._chartATR    = cfg.atr;
  window._chartDec    = cfg.decimals||2;

  // Chart
  buildChart(fc);
}

// ── SYMBOL SWITCH ──────────────────────────────────────────────
function switchSymbol(sym) {
  if (LOCKED.includes(sym)) {
    document.getElementById('symbolSel').value = currentSymbol;
    document.getElementById('subOverlay').classList.add('active');
    return;
  }
  currentSymbol = sym;
  render(sym);
}

// ── REFRESH ────────────────────────────────────────────────────
function refreshData() {
  render(currentSymbol);
  buildTape();
}

// ── SUBSCRIPTION MODAL ─────────────────────────────────────────
function selectPlan(el) {
  document.querySelectorAll('.plan-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
}
function startTrial() {
  alert('Trial coming soon! Connect your email via the stream chat to get early access.');
  closeSub();
}
function closeSub() {
  document.getElementById('subOverlay').classList.remove('active');
}

// ── CLOCK TICK ────────────────────────────────────────────────
function tickClock() {
  const now = new Date();
  document.getElementById('timestamp').textContent =
    now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'}) + '  CT';
}

// ── MAG 10 ENGINE ───────────────────────────────────────────────
const MAG10 = [
  { sym:'AAPL',  name:'Apple',      base:211.50, weight:'8.9%' },
  { sym:'MSFT',  name:'Microsoft',  base:467.20, weight:'8.2%' },
  { sym:'NVDA',  name:'Nvidia',     base:138.85, weight:'7.8%' },
  { sym:'AMZN',  name:'Amazon',     base:224.30, weight:'5.6%' },
  { sym:'META',  name:'Meta',       base:718.40, weight:'4.8%' },
  { sym:'GOOGL', name:'Alphabet',   base:178.90, weight:'4.2%' },
  { sym:'TSLA',  name:'Tesla',      base:342.60, weight:'3.9%' },
  { sym:'SPCX',  name:'SpaceX',     base:165.00, weight:'🚀 NEW' },
  { sym:'AMD',   name:'AMD',        base:168.40, weight:'Semi' },
  { sym:'NFLX',  name:'Netflix',    base:1312.80,weight:'2.6%' },
];

// Simulate correlated moves — when NQ is bullish, stocks lean bullish too
function buildMag10() {
  const nqBias = document.getElementById('biasScore')?.textContent || 'NEUTRAL';
  const bullLean = nqBias === 'BULLISH' ? 0.55 : nqBias === 'BEARISH' ? 0.42 : 0.50;

  const grid = document.getElementById('mag10Grid');
  if (!grid) return;

  grid.innerHTML = MAG10.map(stock => {
    // Correlated but independent — each stock has its own vol
    const stockVol = stock.base * 0.012;
    const drift = (Math.random() < bullLean ? 1 : -1) * Math.random() * stockVol * 0.4;
    const px = stock.base + drift + (Math.random() - 0.5) * stockVol * 0.3;
    const chgPct = (drift / stock.base) * 100;
    const isUp = chgPct >= 0;

    // Format price — stocks over $1000 show no cents on small display
    const pxFmt = stock.base >= 1000
      ? px.toLocaleString('en-US', { minimumFractionDigits:0, maximumFractionDigits:0 })
      : px.toLocaleString('en-US', { minimumFractionDigits:2, maximumFractionDigits:2 });

    const extraClass = stock.sym === 'SPCX' ? ' spcx-card' : '';
    return `<div class="mag10-card ${isUp?'bull-card':'bear-card'}${extraClass}" role="listitem" aria-label="${stock.name}: $${pxFmt}, ${isUp?'up':'down'} ${Math.abs(chgPct).toFixed(2)} percent">
      <div class="mag10-sym">${stock.sym}</div>
      <div class="mag10-px">$${pxFmt}</div>
      <div class="mag10-chg ${isUp?'up':'dn'}">${isUp?'▲':'▼'}${Math.abs(chgPct).toFixed(2)}%</div>
      <div class="mag10-weight">${stock.weight} QQQ</div>
    </div>`;
  }).join('');
}

// ── INIT ───────────────────────────────────────────────────────
buildTape();
render('NQ');
buildMag10();
setInterval(tickClock, 1000);
setInterval(() => {
  buildTape();
}, 45000);
setInterval(() => {
  buildMag10();
}, 30000);
</script>
<script>
(function(){
  if(!window.Chart) return;
  Chart.register({
    id:'lvLines',
    afterDraw:function(ch){
      if(!window._chartLevels||!window._chartLevels.length) return;
      var c=ch.ctx,ya=ch.scales.y,xa=ch.scales.x;
      var L=xa.left,R=xa.right;
      var lineEnd=L+(R-L)*0.28;
      var atr=window._chartATR||200;
      var dec=window._chartDec||2;
      c.save();
      window._chartLevels.forEach(function(lv){
        if(lv.val<ya.min||lv.val>ya.max) return;
        var y=ya.getPixelForValue(lv.val);
        var near=Math.abs(lv.val-(window._chartPrice||0))<atr*0.4;
        var col=lv.cls==='lv-res'?'#ff3b5c':lv.cls==='lv-sup'?'#00ff94':lv.cls==='lv-poc'?'#00d4ff':'#ffb800';
        c.beginPath();
        c.strokeStyle=col;
        c.globalAlpha=near?0.8:0.3;
        c.lineWidth=near?1.5:0.8;
        c.setLineDash(near?[]:[3,4]);
        c.moveTo(L,y);c.lineTo(lineEnd,y);c.stroke();
        c.setLineDash([]);
        c.globalAlpha=near?0.95:0.45;
        c.font=(near?'bold ':'')+'10px JetBrains Mono,monospace';
        c.fillStyle=col;
        c.textAlign='left';
        var val=lv.val.toLocaleString('en-US',{minimumFractionDigits:dec,maximumFractionDigits:dec});
        c.fillText(lv.tag+' '+val,lineEnd+3,y+4);
        c.globalAlpha=1;
      });
      c.restore();
    }
  });
  console.log('[LevelLines] Chart plugin registered');
})();</script>
