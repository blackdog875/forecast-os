<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FORECAST OS — NQ/MNQ Terminal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #060810;
    --bg2:       #0a1628;
    --bg3:       #080f1e;
    --cyan:      #00d4ff;
    --cyan-dim:  rgba(0,212,255,0.18);
    --cyan-glow: rgba(0,212,255,0.08);
    --bull:      #00ff94;
    --bear:      #ff3b5c;
    --amber:     #ffb800;
    --text:      #c8d8f0;
    --text-dim:  rgba(200,216,240,0.45);
    --text-faint:rgba(200,216,240,0.2);
    --border:    rgba(0,212,255,0.14);
    --border-hi: rgba(0,212,255,0.35);
  }

  html, body {
    background: var(--bg);
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 18px;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── SCANLINE OVERLAY ── */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* ── LAYOUT ── */
  .terminal {
    max-width: 100%;
    margin: 0 auto;
    padding: 72px 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 100vh;
  }

  /* ── HEADER ── */
  .hdr {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border-hi);
  }
  .hdr-left { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .logo {
    font-family: 'Orbitron', sans-serif;
    font-size: 15px; font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--cyan);
    text-transform: uppercase;
  }
  .logo span { color: rgba(0,212,255,0.4); }
  .vsep { width: 1px; height: 22px; background: var(--border-hi); }
  .ticker-lbl {
    font-family: 'Orbitron', sans-serif;
    font-size: 32px; font-weight: 900;
    color: #fff; letter-spacing: 0.08em;
  }
  .price-display {
    font-family: 'JetBrains Mono', monospace;
    font-size: 24px; font-weight: 700;
    color: #fff; letter-spacing: 0.04em;
  }
  .chg-badge {
    font-size: 16px; font-weight: 600;
    padding: 5px 14px; border-radius: 3px;
    letter-spacing: 0.05em;
  }
  .chg-up   { color: var(--bull); background: rgba(0,255,148,0.1); border: 1px solid rgba(0,255,148,0.25); }
  .chg-down { color: var(--bear); background: rgba(255,59,92,0.1);  border: 1px solid rgba(255,59,92,0.25); }
  .hdr-right { display: flex; align-items: center; gap: 12px; }
  .live-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--bull);
    animation: blink 1.8s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
  .timestamp { font-size: 14px; color: var(--text-dim); letter-spacing: 0.07em; }
  .symbol-selector {
    background: var(--bg2);
    border: 1px solid var(--border-hi);
    border-radius: 4px;
    color: var(--cyan);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 4px 10px;
    cursor: pointer;
    letter-spacing: 0.08em;
  }

  /* ── METRIC STRIP ── */
  .metrics {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }
  .mc {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 9px 12px;
    position: relative;
    overflow: hidden;
  }
  .mc::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
  }
  .mc.cyan-top::after  { background: var(--cyan); }
  .mc.bull-top::after  { background: var(--bull); }
  .mc.bear-top::after  { background: var(--bear); }
  .mc.amber-top::after { background: var(--amber); }
  .mc-lbl {
    font-size: 12px; letter-spacing: 0.14em;
    color: var(--text-dim); text-transform: uppercase;
    margin-bottom: 6px;
  }
  .mc-val { font-size: 26px; font-weight: 700; color: #e8f0ff; }
  .mc-sub { font-size: 12px; color: var(--text-faint); margin-top: 3px; }

  /* ── MAIN BODY ── */
  .body-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 10px;
  }

  /* ── CHART PANEL ── */
  .chart-panel {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 14px;
  }
  .chart-hdr {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .chart-title {
    font-size: 13px; letter-spacing: 0.14em;
    color: var(--text-dim); text-transform: uppercase;
  }
  .legend {
    display: flex; gap: 14px;
  }
  .leg-item {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--text-dim);
  }
  .leg-dot {
    width: 9px; height: 9px; border-radius: 2px;
  }
  .chart-canvas-wrap {
    position: relative;
    width: 100%; height: 420px;
  }

  /* ── SIDEBAR ── */
  .sidebar { display: flex; flex-direction: column; gap: 8px; }
  .panel {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px 18px;
  }
  .panel-title {
    font-size: 13px; letter-spacing: 0.14em;
    color: var(--text-dim); text-transform: uppercase;
    padding-bottom: 9px; margin-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  /* Bias bars */
  .bias-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .bias-row:last-child { margin-bottom: 0; }
  .bias-tag { font-size: 14px; width: 48px; letter-spacing: 0.05em; }
  .bar-track {
    flex: 1; height: 5px;
    background: rgba(255,255,255,0.05);
    border-radius: 3px; overflow: hidden;
  }
  .bar-fill { height: 100%; border-radius: 3px; transition: width 1.2s ease; }
  .fill-bull { background: var(--bull); }
  .fill-bear { background: var(--bear); }
  .fill-neu  { background: var(--cyan); }
  .bias-pct { font-size: 15px; font-weight: 700; width: 46px; text-align: right; }

  /* Key levels */
  .level-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 6px 8px;
    border-radius: 3px;
    margin-bottom: 3px;
    border: 1px solid transparent;
    transition: background 0.15s;
    font-size: 15px;
  }
  .level-row:last-child { margin-bottom: 0; }
  .level-row.row-res { background: rgba(255,59,92,0.06); border-color: rgba(255,59,92,0.15); }
  .level-row.row-sup { background: rgba(0,255,148,0.06); border-color: rgba(0,255,148,0.15); }
  .level-row.row-poc { background: rgba(0,212,255,0.06); border-color: rgba(0,212,255,0.2); }
  .level-row.row-pvt { background: rgba(255,184,0,0.06); border-color: rgba(255,184,0,0.2); }
  .lv-tag { letter-spacing: 0.1em; font-size: 12px; font-weight: 700; padding: 2px 7px; border-radius: 3px; }
  .lv-tag-res { color: var(--bear); background: rgba(255,59,92,0.15); border: 1px solid rgba(255,59,92,0.3); }
  .lv-tag-sup { color: var(--bull); background: rgba(0,255,148,0.12); border: 1px solid rgba(0,255,148,0.3); }
  .lv-tag-poc { color: var(--cyan); background: rgba(0,212,255,0.1);  border: 1px solid rgba(0,212,255,0.3); }
  .lv-tag-pvt { color: var(--amber);background: rgba(255,184,0,0.1);  border: 1px solid rgba(255,184,0,0.3); }
  .lv-res { color: var(--bear); font-weight: 700; font-size: 15px; }
  .lv-sup { color: var(--bull); font-weight: 700; font-size: 15px; }
  .lv-poc { color: var(--cyan); font-weight: 700; font-size: 15px; }
  .lv-pvt { color: var(--amber);font-weight: 700; font-size: 15px; }

  /* Confluence */
  .conf-line {
    font-size: 13px; line-height: 2.2;
    color: var(--text-dim);
  }
  .conf-bull { color: var(--bull); }
  .conf-bear { color: var(--bear); }

  /* ── TF GRID ── */
  .tf-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }
  .tf-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 12px;
    text-align: center;
  }
  .tf-name {
    font-size: 12px; letter-spacing: 0.1em;
    color: var(--text-dim); text-transform: uppercase;
    margin-bottom: 5px;
  }
  .tf-signal { font-size: 17px; font-weight: 700; margin-bottom: 4px; }
  .tf-detail { font-size: 11px; color: var(--text-faint); }
  .sig-bull { color: var(--bull); }
  .sig-bear { color: var(--bear); }
  .sig-neu  { color: var(--amber); }

  /* ── BOTTOM BAR ── */
  .bottom-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 8px;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 8px;
  }
  .disclaimer {
    font-size: 11px; letter-spacing: 0.06em;
    color: rgba(200,216,240,0.2);
  }
  .btn-group { display: flex; gap: 8px; align-items: center; }
  .btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px; letter-spacing: 0.1em;
    padding: 8px 20px; border-radius: 3px;
    cursor: pointer; border: none;
  }
  .btn-primary {
    background: var(--cyan);
    color: #060810; font-weight: 700;
  }
  .btn-primary:hover { background: #00eeff; }
  .btn-outline {
    background: transparent;
    color: var(--cyan);
    border: 1px solid var(--border-hi);
  }
  .btn-outline:hover { background: var(--cyan-dim); }

  /* ── SUBSCRIPTION OVERLAY ── */
  .sub-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(6,8,16,0.92);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .sub-overlay.active { display: flex; }
  .sub-modal {
    background: var(--bg2);
    border: 1px solid var(--border-hi);
    border-radius: 8px;
    padding: 36px 40px;
    max-width: 520px;
    width: 90%;
    text-align: center;
  }
  .sub-logo {
    font-family: 'Orbitron', sans-serif;
    font-size: 13px; font-weight: 700;
    letter-spacing: 0.2em; color: var(--cyan);
    margin-bottom: 8px;
  }
  .sub-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 20px; font-weight: 700;
    color: #fff; margin-bottom: 6px;
  }
  .sub-sub { font-size: 11px; color: var(--text-dim); margin-bottom: 28px; line-height: 1.7; }
  .plan-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 24px; }
  .plan-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 14px 10px;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .plan-card:hover, .plan-card.selected {
    border-color: var(--cyan);
    background: var(--cyan-glow);
  }
  .plan-card.featured { border-color: var(--amber); }
  .plan-name { font-size: 9px; letter-spacing: 0.12em; color: var(--text-dim); text-transform: uppercase; margin-bottom: 6px; }
  .plan-price { font-family: 'Orbitron', sans-serif; font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 3px; }
  .plan-period { font-size: 9px; color: var(--text-dim); margin-bottom: 8px; }
  .plan-badge {
    display: inline-block; font-size: 8px; letter-spacing: 0.1em;
    padding: 2px 8px; border-radius: 2px;
    background: rgba(255,184,0,0.15); color: var(--amber);
    border: 1px solid rgba(255,184,0,0.3);
  }
  .plan-features { font-size: 9px; color: var(--text-dim); line-height: 1.9; text-align: left; margin-top: 8px; }
  .sub-trial { font-size: 10px; color: var(--bull); margin-bottom: 14px; }
  .sub-close { font-size: 9px; color: var(--text-faint); cursor: pointer; text-decoration: underline; margin-top: 10px; display: block; }
  .sub-close:hover { color: var(--text-dim); }

  /* ── TICKER TAPE ── */
  .ticker-tape {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 3px;
    overflow: hidden;
    height: 38px;
    display: flex;
    align-items: center;
  }
  .tape-label {
    font-size: 12px; letter-spacing: 0.14em;
    color: var(--cyan); text-transform: uppercase;
    padding: 0 12px; border-right: 1px solid var(--border);
    white-space: nowrap; height: 100%;
    display: flex; align-items: center;
    background: var(--cyan-glow);
  }
  .tape-scroll-wrap { flex: 1; overflow: hidden; }
  .tape-scroll {
    display: flex; align-items: center;
    white-space: nowrap;
    animation: scroll-tape 40s linear infinite;
  }
  @keyframes scroll-tape {
    0%   { transform: translateX(100%); }
    100% { transform: translateX(-100%); }
  }
  .tape-item {
    font-size: 13px; padding: 0 20px;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .tape-sym { color: #fff; font-weight: 700; font-size: 14px; }
  .tape-px  { color: var(--text); }
  .tape-up  { color: var(--bull); }
  .tape-dn  { color: var(--bear); }

  @media (max-width: 900px) {
    .metrics { grid-template-columns: repeat(3, 1fr); }
    .body-grid { grid-template-columns: 1fr; }
    .tf-grid { grid-template-columns: repeat(3, 1fr); }
    .plan-grid { grid-template-columns: 1fr; }
  }

  /* ── SPCX SPECIAL GLOW ── */
  .mag10-card.spcx-card {
    border-color: rgba(0,212,255,0.4) !important;
    background: rgba(0,212,255,0.04) !important;
  }
  .mag10-card.spcx-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 4px;
    box-shadow: 0 0 15px rgba(0,212,255,0.15);
    pointer-events: none;
  }

  /* ── MAG 10 PANEL ── */
  .mag10-panel {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px 14px;
  }
  .mag10-hdr {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .mag10-title {
    font-size: 13px;
    letter-spacing: 0.14em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .mag10-sub {
    font-size: 12px;
    color: var(--text-faint);
    letter-spacing: 0.05em;
  }
  .mag10-grid {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    gap: 6px;
    overflow-x: auto;
    padding-bottom: 4px;
  }
  .mag10-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 10px;
    text-align: center;
    min-width: 110px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
    cursor: default;
  }
  .mag10-card:hover { border-color: var(--border-hi); }
  .mag10-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
  }
  .mag10-card.bull-card::after { background: var(--bull); }
  .mag10-card.bear-card::after { background: var(--bear); }
  .mag10-sym {
    font-family: 'Orbitron', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.06em;
    margin-bottom: 5px;
  }
  .mag10-px {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 3px;
    white-space: nowrap;
  }
  .mag10-chg {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.03em;
  }
  .mag10-chg.up { color: var(--bull); }
  .mag10-chg.dn { color: var(--bear); }
  .mag10-weight {
    font-size: 11px;
    color: var(--text-faint);
    margin-top: 3px;
    letter-spacing: 0.05em;
  }
  @media (max-width: 900px) {
    .mag10-grid { grid-template-columns: repeat(5, 1fr); }
  }

  /* ── TOP NAV ── */
  .top-nav{
    position:fixed;top:0;left:0;right:0;z-index:1000;
    background:rgba(6,8,16,0.95);
    border-bottom:1px solid rgba(0,212,255,0.2);
    backdrop-filter:blur(10px);
    display:flex;align-items:center;justify-content:space-between;
    padding:0 28px;height:52px;
  }
  .top-nav-logo{
    font-family:'Orbitron',sans-serif;font-size:13px;font-weight:700;
    letter-spacing:0.2em;color:#00d4ff;text-decoration:none;
  }
  .top-nav-links{display:flex;align-items:center;gap:4px;flex-wrap:wrap;}
  .top-nav-link{
    font-family:'JetBrains Mono',monospace;
    font-size:10px;letter-spacing:0.1em;
    color:rgba(200,216,240,0.6);text-decoration:none;
    padding:6px 12px;border-radius:3px;
    border:1px solid transparent;
    transition:all 0.15s;white-space:nowrap;
  }
  .top-nav-link:hover{color:#00d4ff;border-color:rgba(0,212,255,0.3);background:rgba(0,212,255,0.06);}
  .top-nav-link.active{color:#00d4ff;border-color:rgba(0,212,255,0.3);background:rgba(0,212,255,0.06);}
  .top-nav-link.highlight{color:#00ff94;border-color:rgba(0,255,148,0.3);background:rgba(0,255,148,0.06);}

</style>
</head>
