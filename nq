<!-- ── MAIN TERMINAL ── -->
<div class="terminal">

  <!-- TICKER TAPE -->
  <div class="ticker-tape">
    <div class="tape-label">FUTURES</div>
    <div class="tape-scroll-wrap">
      <div class="tape-scroll" id="tapeScroll"></div>
    </div>
  </div>

